function parseReport(text) {
  if (!text) return null;
  // 1. Try ```json fenced block
  try {
    const fenced = text.match(/```json\s*([\s\S]*?)\s*```/);
    if (fenced) return JSON.parse(fenced[1]);
  } catch {}
  // 2. Try ``` fenced block (no language tag)
  try {
    const fenced = text.match(/```\s*([\s\S]*?)\s*```/);
    if (fenced) return JSON.parse(fenced[1]);
  } catch {}
  // 3. Try outermost { ... } — most robust
  try {
    const s = text.indexOf("{"), e = text.lastIndexOf("}");
    if (s !== -1 && e > s) return JSON.parse(text.slice(s, e + 1));
  } catch {}
  // 4. Try to fix common JSON issues: trailing commas, single quotes
  try {
    const s = text.indexOf("{"), e = text.lastIndexOf("}");
    if (s !== -1 && e > s) {
      const raw = text.slice(s, e + 1)
        .replace(/,\s*([}\]])/g, "$1")   // trailing commas
        .replace(/'/g, '"');               // single quotes
      return JSON.parse(raw);
    }
  } catch {}
  return null;
}

async function callClaude(brandName, website, socials) {
  const noWebsite = !website || website.trim() === "";
  const socialsText = Object.entries(socials).filter(([,v])=>v).map(([k,v])=>`${k}: ${v}`).join(", ");
  const webLine = noWebsite ? "NO TIENE SITIO WEB — solo presencia en redes sociales" : website;

  const prompt = `Eres un consultor senior de growth y marketing digital. Investiga y analiza el ecosistema digital de esta marca usando informacion publica.

MARCA: ${brandName}
WEB: ${webLine}
REDES SOCIALES: ${socialsText || "No especificadas"}

REGLA CRITICA — SIN SITIO WEB:
Si la marca no tiene sitio web propio (o solo tiene presencia en redes sociales), esto es una alerta maxima. En ese caso:
- owned_media debe tener status "missing" y score maximo de 15
- seo debe tener status "missing" y score de 0
- El summary debe mencionar explicitamente que la marca no tiene canal propio
- Las 3 primeras acciones del roadmap (short) deben ser TODAS sobre crear el sitio web y captura de datos propia
- biggest_opportunity debe ser sobre construir presencia propia
- El gap de owned_media debe ser enfatico: sin web propia la marca no posee ningun canal digital real, es completamente dependiente de plataformas terceras que pueden cambiar algoritmos, cobrar mas, o desaparecer

Devuelve UNICAMENTE un JSON valido. Sin texto antes ni despues. Sin backticks. Sin markdown. Solo JSON puro empezando con { y terminando con }.

{
  "brand_name": "${brandName}",
  "summary": "Resumen ejecutivo de 2-3 frases del ecosistema digital. Tono directo y profesional.",
  "score_global": 65,
  "assets": {
    "owned_media":    { "status": "strong|weak|missing", "score": 75, "observations": "Analiza: 1) CTAs visibles y claridad de la propuesta de accion (hay CTA principal claro, esta above the fold, el copy del CTA es especifico o generico tipo 'click aqui'), 2) Calidad del copy: es generico/corporativo o especifico/diferenciado, habla al cliente o habla de la empresa, 3) UX observable: navegacion clara, jerarquia visual, mobile-first, velocidad percibida, estructura logica del funnel", "gap": "Si no tiene web: SIN CANAL PROPIO — la marca opera 100% en plataformas de terceros, sin propiedad real de audiencia ni datos. Si tiene web debil: gap principal en CTAs, copy o UX" },
    "seo":            { "status": "strong|weak|missing", "score": 50, "observations": "Analiza sin APIs: 1) Estructura tecnica visible: URL amigables, meta titles descriptivos, H1 claro en homepage, sitemap.xml accesible en /sitemap.xml, 2) Contenido SEO: blog activo con frecuencia regular, articulos con keywords en titulos, longitud de contenido suficiente, 3) Senales de autoridad: presencia en directorios, menciones externas visibles, antiguedad del dominio si es detectable, buscar site:dominio.com en Google para estimar indexacion", "gap": "Gap principal de SEO detectado" },
    "content":        { "status": "strong|weak|missing", "score": 50, "observations": "...", "gap": "..." },
    "data":           { "status": "strong|weak|missing", "score": 30, "observations": "Inferir desde senales externas: formularios, popups de captura, newsletter visible", "gap": "..." },
    "performance":    { "status": "strong|weak|missing", "score": 40, "observations": "Inferir desde senales externas: pixels detectables, landing pages, retargeting evidente", "gap": "..." },
    "community":      { "status": "strong|weak|missing", "score": 60, "observations": "...", "gap": "..." },
    "partnerships":   { "status": "strong|weak|missing", "score": 35, "observations": "...", "gap": "..." },
    "technical":      { "status": "strong|weak|missing", "score": 45, "observations": "Inferir desde senales externas del sitio: analytics, chat, herramientas detectables", "gap": "..." }
  },
  "roadmap": {
    "short": [
      {"title": "Accion concreta", "description": "Descripcion breve del impacto y como ejecutarla", "asset": "owned_media"},
      {"title": "...", "description": "...", "asset": "content"},
      {"title": "...", "description": "...", "asset": "data"}
    ],
    "mid": [
      {"title": "...", "description": "...", "asset": "performance"},
      {"title": "...", "description": "...", "asset": "community"},
      {"title": "...", "description": "...", "asset": "technical"}
    ],
    "long": [
      {"title": "...", "description": "...", "asset": "partnerships"},
      {"title": "...", "description": "...", "asset": "data"},
      {"title": "...", "description": "...", "asset": "technical"}
    ]
  },
  "biggest_opportunity": "Una frase que capture la mayor oportunidad de growth para esta marca especifica"
}`;

  // Step 1: Research with web search
  const res1 = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 3000,
      tools: [{ type: "web_search_20250305", name: "web_search" }],
      messages: [{ role: "user", content: prompt }],
    }),
  });
  if (!res1.ok) throw new Error(`API error ${res1.status}`);
  const data1 = await res1.json();

  // Collect all content from step 1 (text + search results)
  const researchSummary = (data1.content || [])
    .map(b => {
      if (b.type === "text") return b.text;
      if (b.type === "tool_result") return JSON.stringify(b.content || "");
      return "";
    })
    .filter(Boolean)
    .join("\n");

  // Try parsing directly from step 1 first
  const textBlocks1 = (data1.content || []).filter(b => b.type === "text").map(b => b.text);
  for (let i = textBlocks1.length - 1; i >= 0; i--) {
    const p = parseReport(textBlocks1[i]);
    if (p && p.assets) return p;
  }

  // Step 2: Force pure JSON generation from research context
  const jsonPrompt = `Basandote en esta investigacion sobre "${brandName}":

${researchSummary.slice(0, 6000)}

${noWebsite ? `IMPORTANTE: La marca NO tiene sitio web propio. Aplica las reglas criticas: owned_media status="missing" score=15, seo status="missing" score=0, roadmap short con 3 acciones sobre construir web y captura de datos.` : ""}

Genera EXCLUSIVAMENTE el siguiente JSON. Absolutamente nada mas. Sin explicaciones. Sin texto. Solo el objeto JSON comenzando con { y terminando con }:

{"brand_name":"${brandName}","summary":"resumen 2-3 frases","score_global":50,"assets":{"owned_media":{"status":"missing","score":15,"observations":"observaciones especificas","gap":"gap detectado"},"seo":{"status":"missing","score":0,"observations":"observaciones","gap":"gap"},"content":{"status":"weak","score":30,"observations":"observaciones","gap":"gap"},"data":{"status":"missing","score":10,"observations":"observaciones","gap":"gap"},"performance":{"status":"missing","score":5,"observations":"observaciones","gap":"gap"},"community":{"status":"weak","score":40,"observations":"observaciones","gap":"gap"},"partnerships":{"status":"missing","score":10,"observations":"observaciones","gap":"gap"},"technical":{"status":"missing","score":5,"observations":"observaciones","gap":"gap"}},"roadmap":{"short":[{"title":"titulo","description":"descripcion","asset":"owned_media"},{"title":"titulo","description":"descripcion","asset":"data"},{"title":"titulo","description":"descripcion","asset":"owned_media"}],"mid":[{"title":"titulo","description":"descripcion","asset":"content"},{"title":"titulo","description":"descripcion","asset":"community"},{"title":"titulo","description":"descripcion","asset":"technical"}],"long":[{"title":"titulo","description":"descripcion","asset":"partnerships"},{"title":"titulo","description":"descripcion","asset":"seo"},{"title":"titulo","description":"descripcion","asset":"performance"}]},"biggest_opportunity":"oportunidad principal"}`;

  const res2 = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 2000,
      messages: [{ role: "user", content: jsonPrompt }],
    }),
  });
  if (!res2.ok) throw new Error(`API error step 2: ${res2.status}`);
  const data2 = await res2.json();

  const textBlocks2 = (data2.content || []).filter(b => b.type === "text").map(b => b.text);
  for (let i = textBlocks2.length - 1; i >= 0; i--) {
    const p = parseReport(textBlocks2[i]);
    if (p && p.assets) return p;
  }
  const p = parseReport(textBlocks2.join("\n"));
  if (p) return p;

  throw new Error("No se pudo generar el reporte. Verifica el nombre de la marca e intenta de nuevo.");
}

